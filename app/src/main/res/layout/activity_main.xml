<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background">

    <!-- Background glowing orb effect -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-150dp"
        android:background="@drawable/bg_glowing_orb"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">                     

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="24dp"
                android:src="@drawable/ic_app"
                android:background="@drawable/circle_bg"
                android:padding="14dp"
                android:tint="@color/accent" />

            <TextView
                android:text="Your Personal\nHelping Assistant"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="This app helps you use your phone easily.\nJust type what you want, and the app will guide you step-by-step."
                android:textSize="16sp"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="40dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- PERMISSION LAYOUT -->
            <LinearLayout
                android:id="@+id/permissionLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/input_bg"
                android:padding="24dp"
                android:elevation="0dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:text="Required Permissions"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/textOverlay"
                    android:text="1. Overlay access controls the floating guide."
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnOverlay"
                    android:text="Overlay Settings"
                    android:background="@drawable/menu_bg"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="false"
                    android:layout_marginBottom="24dp"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"/>

                <TextView
                    android:id="@+id/textAccessibility"
                    android:text="2. Accessibility reads exactly what's on the screen."
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnAccessibility"
                    android:text="Accessibility Settings"
                    android:background="@drawable/menu_bg"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="false"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"/>

            </LinearLayout>

            <!-- CONTROL LAYOUT (Shows after permissions granted) -->
            <LinearLayout
                android:id="@+id/controlLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:gravity="center_horizontal"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btnToggleAssistant"
                    android:text="Start Assistant"
                    android:background="@drawable/menu_bg"
                    android:textColor="@color/accent"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>