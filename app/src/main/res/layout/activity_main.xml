<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background">

    <!-- Background glowing orb effect -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-150dp"
        android:background="@drawable/bg_glowing_orb"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">                     

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="24dp"
                android:src="@drawable/ic_app"
                android:background="@drawable/circle_bg"
                android:padding="16dp"
                android:elevation="4dp"
                android:tint="@color/accent" />

            <TextView
                android:text="Navigation Assistant"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.02"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Your personal guide. Just type what you want, and I'll navigate your device step-by-step."
                android:textSize="15sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="40dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- PERMISSION LAYOUT -->
            <LinearLayout
                android:id="@+id/permissionLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="24dp"
                android:elevation="4dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:text="Required Setup"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Item 1 -->
                <TextView
                    android:id="@+id/textOverlay"
                    android:text="1. Overlay Access"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="0dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                    
                <TextView
                    android:text="Allows the floating assistant icon to display."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginTop="2dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnOverlay"
                    android:text="Enable Overlay"
                    android:background="@drawable/menu_bg"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="24dp"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>

                <!-- Item 2 -->
                <TextView
                    android:id="@+id/textAccessibility"
                    android:text="2. Accessibility Access"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                    
                <TextView
                    android:text="Allows the assistant to read screens and execute navigation actions."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginTop="2dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnAccessibility"
                    android:text="Enable Accessibility"
                    android:background="@drawable/menu_bg"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="false"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>

            </LinearLayout>

            <!-- CONTROL LAYOUT (Shows after permissions granted) -->
            <LinearLayout
                android:id="@+id/controlLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:gravity="center_horizontal"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btnToggleAssistant"
                    android:text="Start Assistant"
                    android:background="@drawable/menu_bg"
                    android:textColor="@color/accent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="false"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnViewLogs"
                    android:text="View AI Logs"
                    android:background="@drawable/menu_bg"
                    android:backgroundTint="#2D3748"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="false"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnViewUITree"
                    android:text="Settings Knowledge Map"
                    android:background="@drawable/menu_bg"
                    android:backgroundTint="#2D3748"
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="false"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnDeviceInfo"
                    android:text="Device Information"
                    android:background="@drawable/menu_bg"
                    android:backgroundTint="#2D3748"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="false"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>


            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>