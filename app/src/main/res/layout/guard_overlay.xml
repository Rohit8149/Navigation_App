<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="0dp">

    <!-- Top banner: full-width persistent alert -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="#EE1A1A2E"
        android:elevation="16dp">

        <!-- Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️"
            android:textSize="22sp"
            android:layout_marginEnd="14dp" />

        <!-- Message block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/guardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open Settings to Continue"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/guardSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Assistant is waiting..."
                android:textColor="#AAAACC"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Timeout indicator -->
        <TextView
            android:id="@+id/guardTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF6B6B"
            android:textSize="12sp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Bottom accent line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="#6C63FF" />

</LinearLayout>
