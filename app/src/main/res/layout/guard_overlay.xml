<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <!-- Floating pill container — SOLID opaque for readability -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="24dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="@drawable/bg_overlay_pill"
        android:elevation="20dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_app"
            android:tint="@color/accent"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/guardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open Settings"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/guardSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assistant is standing by..."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Timeout indicator -->
        <TextView
            android:id="@+id/guardTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/error_red"
            android:textSize="12sp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
